# Copy this file to .env and fill in real values.
#
# Every one of these is read via the same st.secrets -> os.environ fallback
# convention used throughout this codebase, so this single .env file (loaded
# via docker-compose.yml's env_file: .env) is sufficient for a Docker/VPS
# deployment -- no code changes needed to move off Streamlit Cloud. For a
# Streamlit Cloud deployment, set these same names under App settings ->
# Secrets instead (a TOML-formatted secrets.toml equivalent, not this file).

# --- Core / AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key
APP_BASE_URL=https://your-domain.example.com

# --- Supabase (REST client -- utils/db.py, utils/auth.py) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Supabase (direct Postgres connection -- utils/audits.py) ---
# Use the app_audits_rw role's connection string (see
# supabase/migrations/0009_least_privilege_role.sql), NOT the default
# postgres superuser one -- a superuser bypasses every GRANT/REVOKE check,
# which defeats the point of that migration. Transaction pooler mode
# recommended (Supabase Dashboard -> Project Settings -> Database ->
# Connection string).
SUPABASE_DB_URL=postgresql://app_audits_rw:password@your-project-pooler.supabase.co:6543/postgres

# --- Field-level encryption (utils/crypto.py) ---
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing this key makes all encrypted audit content permanently
# unrecoverable -- back it up somewhere outside Supabase/Streamlit secrets.
AUDIT_ENCRYPTION_KEY=your_generated_fernet_key

# --- Paystack (utils/paystack.py) ---
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
# Plan codes from scripts/setup_paystack_plans.py -- Subscribe buttons fall
# back to a one-off charge if any of these three are unset.
PAYSTACK_PLAN_PROFESSIONAL_MONTHLY=
PAYSTACK_PLAN_PROFESSIONAL_ANNUAL=
PAYSTACK_PLAN_AGENCY_MONTHLY=

# --- Flutterwave (utils/flutterwave_payments.py -- USD/GBP/EUR checkout only) ---
# GHS/NGN/KES/ZAR always go through Paystack above; Flutterwave never
# touches those (Stripe was the original choice here, but Stripe requires
# the merchant business to be incorporated in one of its supported
# countries, which does not include Ghana -- Flutterwave supports
# Ghana-registered businesses directly). Plan ids from
# scripts/setup_flutterwave_plans.py -- Subscribe buttons for USD/GBP/EUR
# fail closed (clear error, no charge attempted) if the relevant one is
# unset, since Flutterwave has no one-off-transaction fallback for a
# missing plan the way Paystack's Subscribe buttons do.
# FLUTTERWAVE_WEBHOOK_SECRET_HASH is only used by the
# supabase/functions/flutterwave-webhook Edge Function (set via
# `supabase secrets set`, a separate store from this file/Streamlit secrets),
# listed here for completeness.
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_WEBHOOK_SECRET_HASH=your_flutterwave_webhook_secret_hash
FLUTTERWAVE_PLAN_PROFESSIONAL_MONTHLY_USD=
FLUTTERWAVE_PLAN_PROFESSIONAL_MONTHLY_GBP=
FLUTTERWAVE_PLAN_PROFESSIONAL_MONTHLY_EUR=
FLUTTERWAVE_PLAN_PROFESSIONAL_ANNUAL_USD=
FLUTTERWAVE_PLAN_PROFESSIONAL_ANNUAL_GBP=
FLUTTERWAVE_PLAN_PROFESSIONAL_ANNUAL_EUR=
FLUTTERWAVE_PLAN_AGENCY_MONTHLY_USD=
FLUTTERWAVE_PLAN_AGENCY_MONTHLY_GBP=
FLUTTERWAVE_PLAN_AGENCY_MONTHLY_EUR=

# --- Exchange rates / geolocation (utils/exchange_rates.py, utils/geoip.py) ---
# Pricing/ROI currency selector: daily-cached FX conversion + IP-based
# default currency. Falls back to a static rate table / USD default if
# either key is unset or the API is unreachable -- never blocks checkout.
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key
IP_GEOLOCATION_API_KEY=

# --- Resend (utils/email_otp.py -- magic-link login, transactional email) ---
# Login falls back to unverified email entry if unset.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=ImpactProof <you@yourdomain.com>

# --- WhatsApp Cloud API (utils/whatsapp.py) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Admin ---
# Enables the hidden ?admin=1 usage-metrics view. Leave unset to disable it
# entirely.
ADMIN_PASSPHRASE=
